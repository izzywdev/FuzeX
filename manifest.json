{
  "name": "FuzeX Figma MCP Bridge",
  "id": "fuzex-figma-mcp-bridge",
  "api": "1.0.0",
  "main": "code.js",
  "ui": "ui.html",
  "editorType": ["figma", "figjam"],
  "documentAccess": "dynamic-page",
  "networkAccess": {
    "allowedDomains": [
      "localhost",
      "http://localhost",
      "http://127.0.0.1"
    ],
    "reasoning": "Plugin communicates with the localhost-only MCP bridge server (127.0.0.1 loopback). Wildcard '*' removed — CRITICAL fix for issue #7 [C4]."
  },
  "capabilities": [],
  "permissions": [
    "currentuser"
  ],
  "relaunchButtons": [
    {
      "command": "open-mcp-server",
      "name": "Open MCP Server"
    }
  ],
  "menu": [
    {
      "name": "Start MCP Server",
      "command": "start-server"
    },
    {
      "name": "Stop MCP Server",
      "command": "stop-server"
    }
  ]
}
